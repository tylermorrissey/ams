<h1>Current Projects</h1>
<%= link_to "New Project", new_project_path %>
<div>
  <table>
    <thead>
      <tr>
        <th>Customer Name</th>
        <th>Address</th>
        <th>Job Type</th>
        <th>Employees</th>
        <th>Tools</th>
        <th></th>
        <th></th>
        <th></th>
      </tr>
    </thead>

  <tbody>
    <% if @projects.present? %>
      <% @projects.each do |project| %>
        <tr>
          <td> <%= project.customer_name%> </td>
          <td> <%= project.address%> </td>
          <td> <%= project.job_type%> </td>
          <td> <%= project.employees.map(&:name).join(", ")%> </td>
          <td> <%= project.tools.map(&:name).join(", ")%> </td>

          
          <td><%= link_to "Show", project %></td>
          <td><%= link_to "Edit", edit_project_path(project) %></td>
          <td><%= button_to "Delete", project_path(project), method: :delete,
              data: { turbo_confirm: "Are you sure?" } %> </td>

        </tr>
      <% end %> 
    <% else %>
        <p>You don't have any projects yet. <%= link_to "Add one!", new_project_path %></p>
    <% end %>
  </tbody>
  </table>
</div>
